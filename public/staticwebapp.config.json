{
  "routes": [
    {
      "route": "/projekte",
      "rewrite": "/projekte/index.html"
    },
    {
      "route": "/entscheidungen",
      "rewrite": "/entscheidungen/index.html"
    },
    {
      "route": "/gedanken",
      "rewrite": "/gedanken/index.html"
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html",
      "statusCode": 404
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
