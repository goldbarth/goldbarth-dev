---
import Base from './Base.astro';

interface Props {
  title: string;
  description?: string;
  date: string;
  category: 'projects' | 'decisions' | 'thoughts';
}

const { title, description, date, category } = Astro.props;

const categoryLabel: Record<string, string> = {
  projects: 'Projects',
  decisions: 'Decisions',
  thoughts: 'Thoughts',
};

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={title} description={description}>
  <div class="container">
    <article>
      <header>
        <div class="meta">
          <a href={`/${category}`} class="tag">{categoryLabel[category]}</a>
          <span class="muted">{formattedDate}</span>
        </div>
        <h1>{title}</h1>
        {description && <p class="lead">{description}</p>}
      </header>

      <hr />

      <div class="prose">
        <slot />
      </div>
    </article>
  </div>
</Base>

<style>
  article header {
    margin-bottom: var(--space-lg);
  }

  .meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: var(--space-sm);
  }

  .lead {
    font-size: 1.125rem;
    color: var(--color-muted);
    margin-top: var(--space-sm);
  }

  .prose {
    max-width: 65ch;
  }

  .prose h2 {
    font-size: 1.35rem;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
    color: var(--color-accent);
  }

  .prose h3 {
    font-size: 1.1rem;
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .prose p { margin-top: var(--space-md); }

  .prose ul, .prose ol {
    margin-top: var(--space-md);
    padding-left: var(--space-lg);
  }

  .prose li + li { margin-top: var(--space-xs); }

  .prose blockquote {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-md);
    color: var(--color-muted);
    font-style: italic;
    margin: var(--space-lg) 0;
  }
</style>
