---
import Base from './Base.astro';

interface Props {
  title: string;
  description?: string;
  date: string;          // ISO
  updated?: string;      // ISO, optional
  readMin: number;
  category: 'projects' | 'decisions' | 'thoughts';
}

const { title, description, date, updated, readMin, category } = Astro.props;
const categoryLabel = { projects: 'PROJECT', decisions: 'DECISION', thoughts: 'THOUGHT' }[category];
const iso = date.slice(0, 10);
const updatedIso = updated?.slice(0, 10);
---

<Base title={title} description={description} active={category}>
  <div class="container container--wide">
    <article class="post">
      <header class="post__header">
        <h1 class="post__title">{title}</h1>
        <div class="post__meta">
          <span class="cat">{categoryLabel}</span>
          <span class="sep">·</span>
          <span>{iso}</span>
          <span class="sep">·</span>
          <span>{readMin} min</span>
        </div>
        {updatedIso && <div class="post__updated">updated {updatedIso}</div>}
      </header>

      <div class="prose">
        <slot />
      </div>

      <div class="post__bottom">
        <a href={`/${category}`}>
          <span class="seg">~/goldbarth/</span>
          <span class="seg-active">{category}</span>
          <span class="seg"> $ </span>
          <span class="ls">ls</span>
        </a>
      </div>
    </article>
  </div>
</Base>
