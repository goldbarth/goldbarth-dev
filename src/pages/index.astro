---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ExperimentCard from '../components/ExperimentCard.astro';
import FilterBar from '../components/FilterBar.astro';
import LogRow from '../components/LogRow.astro';
import { lastChange } from '../lib/experiments';

const experiments = await getCollection('experiments');
const entries = await getCollection('log', ({ data }) => !data.draft);

// Layer 2: only running, newest change on top. The block maintains itself,
// because the sort key is the log rather than a hand-kept list.
const running = experiments
  .filter((e) => e.data.status === 'running')
  .sort((a, b) => lastChange(b).getTime() - lastChange(a).getTime());

// Layer 3: the line, newest first. Each row resolves its experiment once here
// so the row component stays free of collection lookups.
const bySlug = new Map(experiments.map((e) => [e.slug, e]));
const line = entries
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((entry) => {
    const exp = entry.data.experiment ? bySlug.get(entry.data.experiment) : undefined;
    return {
      entry,
      origin: exp
        ? {
            title: exp.data.title,
            slug: exp.slug,
            status: exp.data.status,
            tags: exp.data.tags,
          }
        : null,
    };
  });

const tags = [...new Set(experiments.flatMap((e) => e.data.tags))].sort();
---

<Base title="Field notes">
  <div class="page">

    <section class="head">
      <p class="head__prompt">~/goldbarth $ whoami</p>
      <p class="head__text measure">
        Felix Wahl, backend engineer in Hamburg, working toward AI engineering in .NET and Python.
        Posts go up while the experiment is still running. They carry a status, and they change when the result does.
      </p>
    </section>

    <section class="layer">
      <h2 class="layer__head kicker">running experiments</h2>
      {running.map((experiment) => <ExperimentCard experiment={experiment} />)}
    </section>

    <section class="layer">
      <h2 class="layer__head kicker">the line</h2>
      <FilterBar tags={tags} />
      {line.map(({ entry, origin }) => (
        <LogRow
          title={entry.data.title}
          slug={entry.slug}
          date={entry.data.date}
          teaser={entry.data.teaser}
          experiment={origin}
        />
      ))}
    </section>

  </div>
</Base>

<style>
  .head {
    padding-top: var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .head__prompt {
    font-family: var(--font-mono);
    font-size: var(--fs-prompt);
    color: var(--prompt);
  }

  .head__text {
    font-size: var(--fs-head);
    color: var(--body);
  }

  .layer { margin-top: var(--sp-6); }
  .layer__head { margin-bottom: var(--sp-3); }
</style>
