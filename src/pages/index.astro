---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import EntryRow from '../components/EntryRow.astro';
import ProjectRow from '../components/ProjectRow.astro';

// Curated featured projects — kept manual, since these are the recruiter layer.
// Move to a content collection once the list grows.
const featuredProjects = [
  {
    title: 'Ingestor',
    slug: 'ingestor',
    status: 'live' as const,
    description: 'A .NET 10 import pipeline built around reliability: outbox pattern, strict domain state machine, idempotent processing, and a config-switchable dispatch strategy — every design decision focused on correctness and auditability.',
    stack: ['.NET 10', 'OpenTelemetry', 'Postgres', 'EF Core 10', 'Docker', 'ASP.NET Core Minimal API'],
    links: [
      { label: 'github.com/goldbarth/ingestor', href: 'https://github.com/goldbarth/Ingestor' },
    ],
  },
  {
    title: 'ServiceDeskLite',
    slug: 'service-desk-lite',
    status: 'archived' as const,
    description: 'A .NET 10 backend reference built around strict layering: compiler-enforced boundaries, two interchangeable persistence adapters, and result-based error handling — every architectural decision documented and justified.',
    stack: ['.NET 10', 'Postgres', 'EF Core 10', 'Docker', 'ASP.NET Core Minimal API'],
    links: [
      { label: 'github.com/goldbarth/service-desk-lite', href: 'https://github.com/goldbarth/ServiceDeskLite' },
    ],
  },
];

// Latest 6 across decisions + thoughts (projects have their own block).
const writings = (
  await Promise.all([
    getCollection('decisions', ({ data }) => !data.draft),
    getCollection('thoughts', ({ data }) => !data.draft),
  ])
)
  .flat()
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 6);
---

<Base title="Home">
  <div class="container">

    <section class="intro">
      <p>
        Felix Wahl — .NET Backend Engineer focused on distributed
        systems — reliability, consistency, and the stuff nobody talks about until it breaks.
      </p>
      <p>
        Notes from the work: reasoning behind technical decisions,
        half-baked thoughts, and what I'm currently building.
        Unpolished, mostly for my future self — public in case it helps someone.
      </p>
      <div class="intro__now">
        <span>sketching out the next one — something around auth, caching, and modular architecture · reading project hail mary — andy weir</span>
      </div>
    </section>

    <section class="section">
      <header class="section__head">
        <h2 class="section__title">Projects</h2>
        <a class="section__more" href="/projects">all projects →</a>
      </header>
      <div>
        {featuredProjects.map((p) => (
          <ProjectRow
            title={p.title}
            description={p.description}
            status={p.status}
            stack={p.stack}
            links={p.links}
            href={p.slug ? `/projects/${p.slug}` : undefined}
          />
        ))}
      </div>
    </section>

    <section class="section">
      <header class="section__head">
        <h2 class="section__title">Writing</h2>
        <a class="section__more" href="/writings">all writing →</a>
      </header>
      <div class="list">
        {writings.length === 0 ? (
          <p class="muted">No posts yet.</p>
        ) : (
          writings.map((post) => (
            <EntryRow
              title={post.data.title}
              description={post.data.description ?? ''}
              date={post.data.date.toISOString()}
              readMin={post.data.readMin ?? 3}
              category={post.collection as 'decisions' | 'thoughts'}
              slug={post.slug}
            />
          ))
        )}
      </div>
    </section>

  </div>
</Base>
