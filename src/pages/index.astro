---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import EntryRow from '../components/EntryRow.astro';
import ProjectRow from '../components/ProjectRow.astro';

// Curated featured projects — kept manual, since these are the recruiter layer.
// Move to a content collection once the list grows.
const featuredProjects = [
  {
    title: 'MetricGate',
    slug: 'metric-gate',
    status: 'live' as const,
    description: 'Tenant-aware Quota- und Rate-Limiting-Backend für SaaS-APIs. Drei unabhängig deploybare .NET 10 Services — Plans, Enforcement, Usage — mit Redis, Redpanda (Kafka API) und Keycloak OIDC. V1 (Backend) released. V2 (Angular Frontend) in Planung.',
    stack: ['.NET 10', 'Redis', 'Redpanda', 'Keycloak', 'PostgreSQL', 'EF Core 10', 'OpenTelemetry', 'Docker'],
    links: [
      { label: 'github.com/goldbarth/metric-gate', href: 'https://github.com/goldbarth/MetricGate' },
    ],
  },
  {
    title: 'Ingestor',
    slug: 'ingestor',
    status: 'live' as const,
    description: 'Eine .NET 10 Import-Pipeline, gebaut um Reliability: Outbox Pattern, strikte Domain State Machine, idempotente Verarbeitung und eine config-switchable Dispatch-Strategie — jede Design-Entscheidung auf Korrektheit und Nachvollziehbarkeit ausgerichtet.',
    stack: ['.NET 10', 'OpenTelemetry', 'Postgres', 'EF Core 10', 'Docker', 'ASP.NET Core Minimal API'],
    links: [
      { label: 'github.com/goldbarth/ingestor', href: 'https://github.com/goldbarth/Ingestor' },
    ],
  },
  {
    title: 'ServiceDeskLite',
    slug: 'service-desk-lite',
    status: 'live' as const,
    description: 'Eine .NET 10 Backend-Referenz, gebaut um striktes Layering: compiler-enforced Boundaries, zwei austauschbare Persistence-Adapter und result-basiertes Error Handling — jede architektonische Entscheidung dokumentiert und begründet.',
    stack: ['.NET 10', 'Postgres', 'EF Core 10', 'Docker', 'ASP.NET Core Minimal API'],
    links: [
      { label: 'github.com/goldbarth/service-desk-lite', href: 'https://github.com/goldbarth/ServiceDeskLite' },
    ],
  },
];

// Latest 6 across decisions + thoughts (projects have their own block).
const writings = (
  await Promise.all([
    getCollection('decisions', ({ data }) => !data.draft),
    getCollection('thoughts', ({ data }) => !data.draft),
  ])
)
  .flat()
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 6);
---

<Base title="Home">
  <div class="container">

    <section class="intro">
      <p>
        Felix Wahl — .NET Backend Engineer mit Fokus auf distributed
        systems — Reliability, Consistency, und das Zeug, über das niemand redet, bis es kaputt ist.
      </p>
      <p>
        Notizen aus der Arbeit: Überlegungen hinter technischen Entscheidungen,
        halbgare Gedanken und was ich gerade baue.
        Unfertig, hauptsächlich für mein zukünftiges Ich — öffentlich, falls es jemandem hilft.
      </p>
      <div class="intro__now">
        <span>metricgate v1 released · baue v2 — frontend mit angular · lese project hail mary — andy weir</span>
      </div>
    </section>

    <section class="section">
      <header class="section__head">
        <h2 class="section__title">Projekte</h2>
        <a class="section__more" href="/projects">alle Projekte →</a>
      </header>
      <div>
        {featuredProjects.map((p) => (
          <ProjectRow
            title={p.title}
            description={p.description}
            status={p.status}
            stack={p.stack}
            links={p.links}
            href={p.slug ? `/projects/${p.slug}` : undefined}
          />
        ))}
      </div>
    </section>

    <section class="section">
      <header class="section__head">
        <h2 class="section__title">Artikel</h2>
        <a class="section__more" href="/writings">alle Artikel →</a>
      </header>
      <div class="list">
        {writings.length === 0 ? (
          <p class="muted">Noch keine Artikel.</p>
        ) : (
          writings.map((post) => (
            <EntryRow
              title={post.data.title}
              description={post.data.description ?? ''}
              date={post.data.date.toISOString()}
              readMin={post.data.readMin ?? 3}
              category={post.collection as 'decisions' | 'thoughts'}
              slug={post.slug}
            />
          ))
        )}
      </div>
    </section>

  </div>
</Base>
