---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import EntryRow from '../../components/EntryRow.astro';

const posts = (
  await Promise.all([
    getCollection('decisions', ({ data }) => !data.draft),
    getCollection('thoughts', ({ data }) => !data.draft),
  ])
)
  .flat()
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Writings" active="writings">
  <div class="container">
    <section class="cat-intro">
      <h1>writings</h1>
      <p>
        All notes, decisions, and half-baked thoughts — sorted by date.
        Unpolished, mostly for my future self.
      </p>
    </section>

    <div class="list">
      {posts.length === 0 ? (
        <p class="muted">No posts yet.</p>
      ) : (
        posts.map((post) => (
          <EntryRow
            title={post.data.title}
            description={post.data.description ?? ''}
            date={post.data.date.toISOString()}
            readMin={post.data.readMin ?? 3}
            category={post.collection as 'decisions' | 'thoughts'}
            slug={post.slug}
          />
        ))
      )}
    </div>
  </div>
</Base>
