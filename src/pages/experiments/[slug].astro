---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Wordmark from '../../components/Wordmark.astro';
import StatusDot from '../../components/StatusDot.astro';
import StatusLog from '../../components/StatusLog.astro';
import TagList from '../../components/TagList.astro';
import { entriesOf, iso } from '../../lib/experiments';

export async function getStaticPaths() {
  const experiments = await getCollection('experiments');
  const allEntries = await getCollection('log', ({ data }) => !data.draft);

  return experiments.map((experiment) => ({
    params: { slug: experiment.slug },
    // Ascending: the experiment page is a story, and a story is read from
    // the front. The newest one is marked instead of moved.
    props: { experiment, thread: entriesOf(experiment.slug, allEntries) },
  }));
}

interface Props {
  experiment: CollectionEntry<'experiments'>;
  thread: CollectionEntry<'log'>[];
}

const { experiment, thread } = Astro.props;
const { title, frame, status, tags } = experiment.data;
const latestSlug = thread.at(-1)?.slug;
---

<Base title={title} description={frame}>
  <div class="page">

    <header class="head">
      <Wordmark />

      <div class="head__top">
        <h1 class="head__title">
          <span
            class={`dot ${status === 'running' ? 'dot--identity' : ''}`}
            aria-hidden="true"></span>
          {title}
        </h1>
        <StatusDot status={status} label />
      </div>

      <p class="head__frame">{frame}</p>

      <TagList tags={tags} />
      <StatusLog experiment={experiment} />
    </header>

    <section class="thread">
      <h2 class="thread__head kicker">
        entries <span class="sep">·</span> {thread.length}
      </h2>

      {thread.length === 0 ? (
        <p class="thread__empty dim">Nothing written down yet.</p>
      ) : (
        thread.map((entry) => (
          <article class={`item ${entry.slug === latestSlug ? 'item--latest' : ''}`}>
            <p class="item__meta mono">
              {iso(entry.data.date)}
              {entry.slug === latestSlug && (
                <>
                  <span class="sep">·</span>
                  <span>latest</span>
                </>
              )}
            </p>
            <h3 class="item__title">
              <a href={`/log/${entry.slug}`}>{entry.data.title}</a>
            </h3>
            <p class="item__teaser measure-frame">{entry.data.teaser}</p>
          </article>
        ))
      )}
    </section>

    <!-- The same step back the entry page ends on, one level up: an entry
         returns to its experiment, an experiment returns to the log. -->
    <p class="back thread__back">
      <a href="/">← back to the log</a>
    </p>

  </div>
</Base>

<style>
  .head {
    padding-top: var(--sp-4);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  /* Question and state on one line, the way the card on the landing page
     shows it. The page is the same object, one level closer. */
  .head__top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--sp-4);
    margin-top: var(--sp-2);
  }

  .head__title {
    font-size: var(--fs-title-exp);
    font-weight: 500;
    color: var(--title);
    line-height: 1.25;
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
  }

  .head__frame {
    font-size: var(--fs-frame);
    line-height: 1.85;
    color: var(--body);
    max-width: var(--w-frame);
  }

  .head :global(.log) { margin-top: var(--sp-2); }

  .thread { margin-top: var(--sp-5); }
  .thread__head { margin-bottom: var(--sp-1); }
  .thread__empty { font-size: var(--fs-teaser); }
  .thread__back { margin-top: var(--sp-4); }

  .item {
    padding: var(--sp-4) 0;
    border-top: 1px solid var(--hairline-soft);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  /* The one teal line on the page: the current state of the story. */
  .item--latest { border-top-color: var(--st-concluded); }
  .item--latest .item__meta { color: var(--st-running); }
  .item--latest .item__meta .sep { color: var(--st-concluded); }

  .item__meta {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }

  .item__title {
    font-size: var(--fs-entry-list);
    font-weight: 500;
    color: var(--title);
    line-height: 1.4;
  }

  .item__title a { transition: color 0.15s; }
  .item__title a:hover { color: var(--identity); }

  .item__teaser {
    font-size: var(--fs-teaser);
    color: var(--body);
  }

  @container page (max-width: 620px) {
    .head__top {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--sp-2);
    }
  }
</style>
