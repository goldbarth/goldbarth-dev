---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import EntryRow from '../../components/EntryRow.astro';

const posts = (await getCollection('decisions', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Decisions" active="decisions">
  <div class="container">
    <section class="cat-intro">
      <h1>decisions</h1>
      <p>
        Begründungen hinter technischen Entscheidungen — hauptsächlich damit
        ich sie später nicht neu aufrollen muss. Was funktioniert hat, was
        nicht, und unter welchen Annahmen.
      </p>
    </section>

    <div class="list">
      {posts.length === 0 ? (
        <p class="muted">Noch keine Einträge.</p>
      ) : (
        posts.map((post) => (
          <EntryRow
            title={post.data.title}
            description={post.data.description ?? ''}
            date={post.data.date.toISOString()}
            readMin={post.data.readMin ?? 3}
            category="decisions"
            slug={post.slug}
          />
        ))
      )}
    </div>
  </div>
</Base>
