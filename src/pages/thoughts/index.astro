---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import EntryRow from '../../components/EntryRow.astro';

const posts = (await getCollection('thoughts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Gedanken" active="thoughts">
  <div class="container">
    <section class="cat-intro">
      <h1>gedanken</h1>
      <p>
        Halbgare Gedanken, Beobachtungen, lose Notizen. Kürzer als Decisions,
        roher als Projects.
      </p>
    </section>

    <div class="list">
      {posts.length === 0 ? (
        <p class="muted">Noch keine Einträge.</p>
      ) : (
        posts.map((post) => (
          <EntryRow
            title={post.data.title}
            description={post.data.description ?? ''}
            date={post.data.date.toISOString()}
            readMin={post.data.readMin ?? 2}
            category="thoughts"
            slug={post.slug}
          />
        ))
      )}
    </div>
  </div>
</Base>
