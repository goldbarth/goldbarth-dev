---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import EntryRow from '../../components/EntryRow.astro';

const posts = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Projects" active="projects">
  <div class="container">
    <section class="cat-intro">
      <h1>projects</h1>
      <p>Things I've built — and what I learned along the way.</p>
    </section>

    <div class="list">
      {posts.length === 0 ? (
        <p class="muted">No posts yet.</p>
      ) : (
        posts.map((post) => (
          <EntryRow
            title={post.data.title}
            description={post.data.description ?? ''}
            date={post.data.date.toISOString()}
            readMin={post.data.readMin ?? 4}
            category="projects"
            slug={post.slug}
          />
        ))
      )}
    </div>
  </div>
</Base>
