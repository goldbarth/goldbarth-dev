---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';

const posts = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Projects" description="Things I've built – what's behind them and what I took away.">
  <div class="container">
    <header class="page-header">
      <span class="tag">Projects</span>
      <h1>Things I've built.</h1>
      <p class="muted">
        No README dump. What was the problem, what did I decide,
        what would I do differently.
      </p>
    </header>

    {posts.length === 0 ? (
      <p class="muted">No posts yet.</p>
    ) : (
      <div class="post-list">
        {posts.map(post => (
          <PostCard
            title={post.data.title}
            description={post.data.description ?? ''}
            date={post.data.date.toISOString()}
            category="projects"
            slug={post.slug}
          />
        ))}
      </div>
    )}
  </div>
</Base>

<style>
  .page-header {
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-xl);
  }
  .page-header .tag { margin-bottom: var(--space-md); }
  h1 {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    margin: var(--space-sm) 0;
  }
  .post-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
</style>
