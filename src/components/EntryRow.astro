---
interface Props {
  title: string;
  description?: string;
  date: string;          // ISO
  readMin: number;
  category: 'projects' | 'decisions' | 'thoughts';
  slug: string;
}
const { title, description, date, readMin, category, slug } = Astro.props;
const categoryLabel = { projects: 'PROJECT', decisions: 'DECISION', thoughts: 'THOUGHT' }[category];
const iso = date.slice(0, 10);
---

<article class="entry">
  <h3 class="entry__title">
    <a href={`/${category}/${slug}`}>{title}</a>
  </h3>
  <div class="entry__meta">
    <span class="cat">{categoryLabel}</span>
    <span class="sep">·</span>
    <span>{iso}</span>
    <span class="sep">·</span>
    <span>{readMin} min</span>
  </div>
  {description && <p class="entry__desc">{description}</p>}
</article>
