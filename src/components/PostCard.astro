---
interface Props {
  title: string;
  description?: string;
  date: string;
  category: 'projects' | 'decisions' | 'thoughts';
  slug: string;
}

const { title, description, date, category, slug } = Astro.props;

const categoryLabel: Record<string, string> = {
  projects: 'Projects',
  decisions: 'Decisions',
  thoughts: 'Thoughts',
};

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/${category}/${slug}`} class="card">
  <div class="card-meta">
    <span class="tag">{categoryLabel[category]}</span>
    <span class="muted">{formattedDate}</span>
  </div>
  <h2>{title}</h2>
  {description && <p class="muted">{description}</p>}
</a>

<style>
  .card {
    display: block;
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: border-color 0.15s, background 0.15s;
    color: var(--color-text);
  }

  .card:hover {
    border-color: var(--color-accent-dim);
    background: var(--color-surface);
    text-decoration: none;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  h2 {
    font-size: 1.1rem;
    margin-bottom: var(--space-xs);
  }

  p {
    font-size: 0.9rem;
    line-height: 1.5;
    margin-top: var(--space-xs);
  }
</style>
