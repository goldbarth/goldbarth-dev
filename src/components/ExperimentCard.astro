---
import type { CollectionEntry } from 'astro:content';
import { statusClass, iso, startedAt } from '../lib/experiments';
import StatusDot from './StatusDot.astro';
import TagList from './TagList.astro';

interface Props {
  experiment: CollectionEntry<'experiments'>;
  /** entries published under this experiment */
  entryCount: number;
  /** date of the newest entry, null while nothing is written down */
  lastEntry: Date | null;
}

const { experiment, entryCount, lastEntry } = Astro.props;
const { title, frame, status, tags } = experiment.data;
const started = startedAt(experiment);
---

<article class={`card card--${statusClass(status)}`}>
  <div class="card__top">
    <h2 class="card__title">
      <span
        class={`dot ${status === 'running' ? 'dot--identity' : ''}`}
        aria-hidden="true"></span>
      <a href={`/experiments/${experiment.slug}`}>{title}</a>
    </h2>
    <StatusDot status={status} label />
  </div>

  <p class="card__frame">{frame}</p>

  <!-- The card counts instead of narrating: when it started, how much is
       written, when it last moved. The full protocol lives one click deeper. -->
  <p class="card__meta mono">
    {started && <>started <span class="card__date">{iso(started)}</span> <span class="sep">·</span> </>}
    {entryCount} {entryCount === 1 ? 'entry' : 'entries'}
    {lastEntry && <> <span class="sep">·</span> last <span class="card__date">{iso(lastEntry)}</span></>}
  </p>

  <TagList tags={tags} />
</article>

<style>
  /* Running carries its state three ways: fill, border colour and the ring
     around the dot. The gap colour of that ring has to be the fill it sits
     on, so the block hands its own surface down. */
  .card {
    border: 1px solid var(--hairline-soft);
    border-radius: var(--radius);
    padding: 12px var(--sp-3);
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    --dot-gap: var(--bg);
  }

  .card--running {
    border-color: var(--border-run);
    background: var(--surface-run);
    --dot-gap: var(--surface-run);
  }

  .card + .card { margin-top: 12px; }

  /* Title and state share one line: the question, and how far it got.
     The state stays right so the left edge of every card reads as a list. */
  .card__top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--sp-4);
  }

  .card__title {
    font-size: var(--fs-title-home);
    font-weight: 500;
    color: var(--title);
    line-height: 1.35;
    display: flex;
    align-items: baseline;
    gap: var(--sp-2);
  }

  .card__title a { transition: color 0.15s; }
  .card__title a:hover { color: var(--identity); }

  .card__frame {
    font-size: var(--fs-frame-home);
    color: var(--body);
  }

  .card__meta { display: block; }
  .card__date { color: var(--body); }

  .card :global(.tags) { margin-top: var(--sp-2); }

  @container page (max-width: 620px) {
    .card__top {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--sp-2);
    }
  }
</style>
