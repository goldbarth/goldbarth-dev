---
interface Props {
  title: string;
  description: string;
  status: 'live' | 'wip' | 'archived';
  stack: string[];
  links: { label: string; href: string }[];
  cover?: string;        // optional placeholder caption / image src
  href?: string;         // optional internal post link
}
const { title, description, status, stack, links, cover, href } = Astro.props;
const statusLabel = { live: 'Live', wip: 'WIP', archived: 'Archived' }[status];
---

<article class="project">
  <header class="project__head">
    <h3 class="project__title">
      {href ? <a href={href}>{title}</a> : title}
    </h3>
    <span class={`project__status project__status--${status}`}>{statusLabel}</span>
  </header>
  <p class="project__desc">{description}</p>
  {cover && <div class="project__cover">{cover}</div>}
  <div class="project__stack">
    {stack.map((s) => <span>{s}</span>)}
  </div>
  <div class="project__links">
    {links.map((l) => <a href={l.href} target="_blank" rel="noopener">{l.label}</a>)}
  </div>
</article>
